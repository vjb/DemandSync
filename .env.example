# ==========================================
# Project DemandSync: Environment Variables
# ==========================================

# ------------------------------------------
# Google Cloud Configuration
# ------------------------------------------
# The identifier for your GCP project
# Format: A numeric or string project ID (e.g., "622472185650" or "my-project-id")
GCP_PROJECT_ID="" 

# Used for internal IAM bindings and service extensions
# Format: A numeric sequence (e.g., "622472185650")
GCP_PROJECT_NUMBER=""

# Primary deployment region for Cloud Run and Vertex AI
# Format: A standard GCP region string (e.g., "us-central1")
GCP_REGION="us-central1"

# ------------------------------------------
# Google Cloud Agent Builder Configuration
# ------------------------------------------
# The ID of the Agent Builder unstructured data store
# Format: A string identifier (e.g., "demandsync-policy-store")
DATA_STORE_ID=""

# The regional location of the data store
# Format: A string identifier (e.g., "global" or "us")
DATA_STORE_LOCATION="global"

# ------------------------------------------
# LLM Authentication
# ------------------------------------------
# Gemini API Key (Required for the dynamic pricing and image generation phases)
# Format: AIzaSy...
GEMINI_API_KEY=""

# ------------------------------------------
# Database Configuration
# ------------------------------------------
# MongoDB Atlas Connection String
# Format: mongodb+srv://<username>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=""
